# Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
DEBUG=False
API_TITLE=AI E-commerce Personalization Platform
API_VERSION=1.0.0

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
EMBEDDING_MODEL=text-embedding-3-small

# Vector Database Configuration
VECTOR_DB_TYPE=faiss  # faiss or pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
FAISS_INDEX_PATH=./data/faiss_index.pkl

# ElasticSearch Configuration
ELASTICSEARCH_HOST=localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Stripe Configuration
STRIPE_API_KEY=your_stripe_api_key
STRIPE_SECRET_KEY=your_stripe_secret_key
PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# Cart API Configuration
CART_API_BASE_URL=http://localhost:8001

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET=ecommerce-personalization

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/ecommerce

# Agent Configuration
AGENT_TEMPERATURE=0.7
MAX_TOKENS=2000

# Recommendation Configuration
MIN_RECOMMENDATION_CONFIDENCE=0.5
MAX_RECOMMENDATIONS=10
